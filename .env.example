OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3.1:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATABASE_URL=postgres://postgres:postgres@localhost:5433/zehut
# Optional: override the bundled system prompt without editing source.
# OPENROUTER_SYSTEM_PROMPT=

# Auth: secret used to sign JWT tokens. Set to a random long string in production.
JWT_SECRET=
# Bootstrap admin: if no users exist on startup and both are set, a user is seeded.
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# Contact pages (דפי קשר): the current campaign label, the A4 row budget,
# and how many rows a "validation pair" warning box costs against the budget.
# Bumping CURRENT_SEASON to a new value makes every citizen available again
# while preserving the history of older pages under their old season value.
CURRENT_SEASON=
CONTACT_PAGE_ROWS=23
CONTACT_PAGE_PAIR_ROWS=4

# !! On production: CORS_ORIGIN should be set to the URL of the frontend application.